local SharedTools = {
    Notify = function(titletxt, text, duration)
        local NotifyGui = Instance.new("ScreenGui")
        NotifyGui.Name = "Notification"
        NotifyGui.Parent = CoreGui

        local Main = Instance.new("Frame", NotifyGui)
        Main.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Main.Position = UDim2.new(1, 5, 0, 50)
        Main.Size = UDim2.new(0, 250, 0, 80)

        local title = Instance.new("TextLabel", Main)
        title.Size = UDim2.new(1, 0, 0, 25)
        title.Text = titletxt
        title.TextColor3 = Color3.new(1,1,1)
        title.BackgroundTransparency = 0.8

        local msg = Instance.new("TextLabel", Main)
        msg.Position = UDim2.new(0, 0, 0, 25)
        msg.Size = UDim2.new(1, 0, 1, -25)
        msg.Text = text
        msg.TextColor3 = Color3.new(1,1,1)
        msg.BackgroundTransparency = 1

        Main:TweenPosition(UDim2.new(1, -260, 0, 50), "Out", "Quad", 0.4, true)
        task.delay(duration, function()
            if Main then
                Main:TweenPosition(UDim2.new(1, 5, 0, 50), "In", "Quad", 0.4, true)
                task.wait(0.5)
                NotifyGui:Destroy()
            end
        end)
    end,

    RunTeleport = function(targets)
        local rise_info = TweenInfo.new(1, Enum.EasingStyle.Linear)
        local move_info = TweenInfo.new(1, Enum.EasingStyle.Linear)
        local bob_info = TweenInfo.new(0.2, Enum.EasingStyle.Linear)

        for i, targetCF in ipairs(targets) do
            local char = player.Character or player.CharacterAdded:Wait()
            local hrp = char:WaitForChild("HumanoidRootPart")
            local hum = char:WaitForChild("Humanoid")

            local riseTween = TweenService:Create(hrp, rise_info, {CFrame = CFrame.new(hrp.Position.X, 500, hrp.Position.Z)})
            riseTween:Play()
            riseTween.Completed:Wait()

            local moveTween = TweenService:Create(hrp, move_info, {CFrame = targetCF})
            moveTween:Play()
            moveTween.Completed:Wait()

            for _ = 1, 15 do
                local up = TweenService:Create(hrp, bob_info, {CFrame = hrp.CFrame * CFrame.new(0, 1, 0)})
                up:Play()
                up.Completed:Wait()

                local down = TweenService:Create(hrp, bob_info, {CFrame = hrp.CFrame * CFrame.new(0, -1, 0)})
                down:Play()
                down.Completed:Wait()
            end

            if i < #targets then
                hum.Health = 0
                player.CharacterAdded:Wait()
                task.wait(0.5)
            end
        end
    end
}

